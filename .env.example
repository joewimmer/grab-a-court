# Template for scripts/ci-fix-agent.ts local environment.
# Copy this file to `.env` and fill in real values. `.env` is gitignored
# and must NEVER be committed. In CI, these are provided via GitHub Secrets.

# Your Cursor API key (https://cursor.com/dashboard/integrations)
CURSOR_API_KEY=crsr_your_api_key_here

# Target repo in "owner/name" form
GITHUB_REPOSITORY=owner/repo

# Failing branch to investigate
FAILED_REF=main

# URL of the failing CI run (optional)
FAILED_RUN_URL=
